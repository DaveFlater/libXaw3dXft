prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@

Name: Xaw3dXft
Description: X Athena Widgets + 3D + FreeType font support
Version: @PACKAGE_VERSION@
Requires: xproto xmu xt xft
Requires.private: x11 xext
Cflags: -I${includedir}
Libs: -L${libdir} -lXaw3dXft -lXft -lfontconfig
